# Cloudflared Token
CLOUDFLARED_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare API Configuration
CLOUDFLARE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_TUNNEL_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Zone Configuration - Choose ONE of the following options:

# Option 1: Single Zone (Legacy)
CLOUDFLARE_ZONE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DOMAIN_NAME=example.com

# Option 2: Multi-Zone (NEW - Recommended for multiple domains)
# Uncomment and configure if you have multiple domains across different zones
# CLOUDFLARE_ZONE_IDS=zone_id_1,zone_id_2,zone_id_3
# DOMAIN_NAMES=example.com,test.com,demo.com

# Optional: Resource Exclusion (NEW)
# Comma-separated regex patterns for domains to ignore
# Example: Exclude Jellyfin and media services for Cloudflare TOS compliance
# IGNORE_PATTERNS=^jellyfin\.,^media\.,^plex\.

# Optional: DNS Cleanup (NEW)
# Automatically remove DNS records for deleted resources (default: true)
# ENABLE_DNS_CLEANUP=true

# Optional: TLS Routes
# Skip routes with TLS configured (default: true)
# Set to false to include TLS-enabled routes
# SKIP_TLS_ROUTES=false

# Optional: Polling Interval
# How often to poll Traefik for changes (default: 10s)
# POLL_INTERVAL=10s

# Optional: Log Level
# Set to "debug" for verbose logging (default: info)
# LOG_LEVEL=debug
